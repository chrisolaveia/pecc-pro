---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
import { areas } from '../data/peccpro-areas'
import { streams, instructors, totalStreams } from '../data/peccpro-streams'

const title = 'Academia · 192 capacitaciones de Network Marketing | PECC'
const description = `Academia PECC: ${totalStreams} capacitaciones en vivo de los últimos 6 meses, 8 áreas de formación (prospección, presentación, cierre, redes sociales, IA, liderazgo, eventos, residual). Dictadas por ${instructors.length}+ líderes activos de la comunidad.`
const keywords = 'academia network marketing, capacitaciones MLM, presentación FWP, prospección network marketing, cierre ventas MLM, mastermind liderazgo, IA network marketing, EquipoGen academia, PECC capacitaciones'

const accentMap = {
  green: 'var(--color-green)',
  blue: 'var(--color-blue-light)',
  sky: 'var(--color-sky)',
  gold: 'var(--color-gold)',
}

// Build "Todos" + 8 areas for filter
const filters = [
  { slug: 'all', emoji: '✨', title: 'Todos', count: streams.length, accent: 'gold' as const },
  ...areas.map((a) => ({
    slug: a.slug,
    emoji: a.emoji,
    title: a.title,
    count: streams.filter((s) => s.area === a.slug).length,
    accent: a.accent,
  })),
]

const videoListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Academia PECC — Capacitaciones de Network Marketing',
  description,
  numberOfItems: streams.length,
  itemListElement: streams.slice(0, 30).map((s, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'VideoObject',
      name: s.title,
      description: `${s.title}${s.instructor ? ` — Capacitación con ${s.instructor}` : ''}`,
      thumbnailUrl: `https://i.ytimg.com/vi/${s.id}/hqdefault.jpg`,
      contentUrl: `https://www.youtube.com/watch?v=${s.id}`,
      embedUrl: `https://www.youtube.com/embed/${s.id}`,
      uploadDate: '2026-01-01',
    },
  })),
}
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  canonical="https://www.pecc.pro/academia"
>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(videoListSchema)}
    slot="head"
  />

  <Nav />

  <main role="main" class="min-h-screen">
    <!-- Hero -->
    <section class="relative pt-32 pb-16 px-6 overflow-hidden dot-bg">
      <div
        class="absolute top-[-100px] right-[-200px] w-[600px] h-[600px] rounded-full pointer-events-none"
        style="background: radial-gradient(circle, rgba(167,230,127,0.18) 0%, transparent 65%);"
      ></div>
      <div
        class="absolute bottom-[-100px] left-[-200px] w-[500px] h-[500px] rounded-full pointer-events-none"
        style="background: radial-gradient(circle, rgba(74,144,217,0.18) 0%, transparent 65%);"
      ></div>

      <div class="relative max-w-5xl mx-auto text-center">
        <div class="section-eyebrow justify-center mb-6">Academia PECC · Últimos 6 meses</div>
        <h1 class="text-5xl md:text-6xl leading-tight mb-6">
          <span class="green-gradient">{totalStreams}</span> capacitaciones,<br />
          dictadas por la comunidad
        </h1>
        <p class="font-sans text-base text-[var(--color-muted)] max-w-2xl mx-auto leading-relaxed mb-10">
          Cada capacitación viene de un líder activo que está aplicando lo que enseña.
          {areas.length} áreas. {instructors.length}+ instructores. Todas en vivo, todas
          construidas por la comunidad.
        </p>

        <div class="flex flex-wrap justify-center gap-6 max-w-3xl mx-auto">
          <div class="text-center">
            <div class="text-4xl font-black text-white" style="font-family: var(--font-display);">{totalStreams}</div>
            <div class="font-sans text-xs tracking-widest uppercase text-[var(--color-muted)] mt-1">Capacitaciones</div>
          </div>
          <div class="hidden sm:block w-px" style="background:rgba(255,255,255,0.1);"></div>
          <div class="text-center">
            <div class="text-4xl font-black text-white" style="font-family: var(--font-display);">{instructors.length}+</div>
            <div class="font-sans text-xs tracking-widest uppercase text-[var(--color-muted)] mt-1">Instructores</div>
          </div>
          <div class="hidden sm:block w-px" style="background:rgba(255,255,255,0.1);"></div>
          <div class="text-center">
            <div class="text-4xl font-black text-white" style="font-family: var(--font-display);">{areas.length}</div>
            <div class="font-sans text-xs tracking-widest uppercase text-[var(--color-muted)] mt-1">Áreas</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Sticky filter bar -->
    <section class="sticky top-0 z-30 py-3 px-6" style="background: rgba(10,22,40,0.93); backdrop-filter: blur(14px); border-bottom: 1px solid rgba(167,230,127,0.12);">
      <div class="max-w-6xl mx-auto flex flex-wrap justify-center gap-2" role="tablist" aria-label="Filtrar capacitaciones por área">
        {filters.map((f, i) => (
          <button
            type="button"
            class="filter-btn font-sans text-xs font-semibold tracking-wide px-3.5 py-2 rounded-full transition-all flex items-center gap-1.5"
            data-area={f.slug}
            aria-pressed={i === 0 ? 'true' : 'false'}
            style={i === 0
              ? `background: var(--color-green); color: var(--color-navy);`
              : `background: transparent; color: var(--color-muted); border: 1px solid rgba(255,255,255,0.1);`
            }
          >
            <span>{f.emoji}</span>
            <span>{f.title}</span>
            <span class="opacity-60 text-[10px]">{f.count}</span>
          </button>
        ))}
      </div>
    </section>

    <!-- Streams grid -->
    <section class="py-16 px-6" style="background: var(--color-navy);">
      <div class="max-w-6xl mx-auto">
        <div id="streams-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {streams.map((s) => (
            <article
              class="stream-card group rounded-2xl overflow-hidden cursor-pointer transition-all duration-300"
              data-area={s.area}
              data-id={s.id}
              data-title={s.title}
              data-instructor={s.instructor || ''}
              style="background: var(--color-surface); border: 1px solid rgba(255,255,255,0.06);"
            >
              <div class="relative aspect-video overflow-hidden" style="background: var(--color-navy);">
                <img
                  src={`https://i.ytimg.com/vi/${s.id}/hqdefault.jpg`}
                  alt={`Capacitación: ${s.title}`}
                  width="480"
                  height="360"
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
                <div
                  class="absolute inset-0 pointer-events-none"
                  style="background: linear-gradient(to top, rgba(10,22,40,0.85) 0%, transparent 50%);"
                ></div>
                <div
                  class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity"
                >
                  <div
                    class="w-14 h-14 rounded-full flex items-center justify-center"
                    style="background: var(--color-green); color: var(--color-navy);"
                  >
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M8 5v14l11-7z" />
                    </svg>
                  </div>
                </div>
              </div>
              <div class="p-4">
                <h3 class="font-sans text-sm font-bold text-white leading-snug line-clamp-2 mb-2" style="min-height: 2.6em;">
                  {s.title.split('|')[0].trim()}
                </h3>
                <div class="flex items-center justify-between gap-2">
                  <span class="font-sans text-[11px] text-[var(--color-muted)] truncate">
                    {s.instructor || 'Sesión grupal'}
                  </span>
                  <span
                    class="font-sans text-[10px] tracking-widest uppercase font-semibold flex-shrink-0"
                    style={`color: ${accentMap[areas.find((a) => a.slug === s.area)?.accent ?? 'green']};`}
                  >
                    {areas.find((a) => a.slug === s.area)?.title ?? s.area}
                  </span>
                </div>
              </div>
            </article>
          ))}
        </div>

        <div id="no-results" class="hidden text-center py-20">
          <p class="font-sans text-sm text-[var(--color-muted)]">No hay capacitaciones en esta área todavía.</p>
        </div>
      </div>
    </section>

    <!-- Outro CTA -->
    <section class="py-16 px-6" style="background: var(--color-surface);">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl mb-4">
          ¿Quieres <span class="green-gradient">enseñar también</span>?
        </h2>
        <p class="font-sans text-sm text-[var(--color-muted)] leading-relaxed mb-8">
          La Academia crece con cada líder que se anima a compartir lo que sabe.
          Si estás aplicando algo que funciona, este es el espacio para multiplicarlo.
        </p>
        <a
          href="https://www.youtube.com/@peccpro"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 font-sans text-sm font-bold px-6 py-3 rounded-lg transition-all btn-primary no-underline"
        >
          Suscribete al canal
        </a>
      </div>
    </section>
  </main>

  <!-- Modal player -->
  <div
    id="player-modal"
    class="hidden fixed inset-0 z-[100] items-center justify-center p-4"
    style="background: rgba(10,22,40,0.94); backdrop-filter: blur(8px);"
    role="dialog"
    aria-modal="true"
    aria-labelledby="modal-title"
  >
    <div class="relative w-full max-w-5xl max-h-[90vh] overflow-y-auto rounded-2xl" style="background: var(--color-surface); border: 1px solid rgba(255,255,255,0.08);">
      <button
        id="modal-close"
        type="button"
        aria-label="Cerrar reproductor"
        class="absolute top-4 right-4 z-10 w-10 h-10 rounded-full flex items-center justify-center transition-all hover:scale-110"
        style="background: rgba(0,0,0,0.6); backdrop-filter: blur(6px); color: white;"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
      <div class="relative w-full aspect-video" style="background: var(--color-navy);">
        <iframe
          id="modal-iframe"
          src=""
          title="Capacitación PECC"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          class="w-full h-full"
          loading="lazy"
        ></iframe>
      </div>
      <div class="p-6">
        <div id="modal-area" class="font-sans text-[10px] tracking-widest uppercase font-semibold mb-2" style="color: var(--color-green);"></div>
        <h3 id="modal-title" class="text-xl font-bold mb-2 text-white" style="font-family: var(--font-display);"></h3>
        <p id="modal-instructor" class="font-sans text-sm text-[var(--color-muted)] mb-4"></p>
        <a id="modal-yt-link" href="" target="_blank" rel="noopener" class="font-sans text-xs font-semibold text-[var(--color-green)] hover:underline">
          Abrir en YouTube ↗
        </a>
      </div>
    </div>
  </div>

  <Footer />

  <script is:inline>
    // Filter
    const filterBtns = document.querySelectorAll('.filter-btn')
    const cards = document.querySelectorAll('.stream-card')
    const noResults = document.getElementById('no-results')

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const area = btn.dataset.area
        filterBtns.forEach((b) => {
          b.setAttribute('aria-pressed', 'false')
          b.style.background = 'transparent'
          b.style.color = 'var(--color-muted)'
          b.style.border = '1px solid rgba(255,255,255,0.1)'
        })
        btn.setAttribute('aria-pressed', 'true')
        btn.style.background = 'var(--color-green)'
        btn.style.color = 'var(--color-navy)'
        btn.style.border = 'none'

        let visible = 0
        cards.forEach((card) => {
          const match = area === 'all' || card.dataset.area === area
          card.style.display = match ? '' : 'none'
          if (match) visible++
        })
        noResults.classList.toggle('hidden', visible > 0)
      })
    })

    // Modal
    const modal = document.getElementById('player-modal')
    const iframe = document.getElementById('modal-iframe')
    const closeBtn = document.getElementById('modal-close')
    const modalTitle = document.getElementById('modal-title')
    const modalInstructor = document.getElementById('modal-instructor')
    const modalArea = document.getElementById('modal-area')
    const modalYtLink = document.getElementById('modal-yt-link')

    const areaLabels = {
      'prospeccion': 'Prospección',
      'presentacion': 'Presentación de Negocio',
      'cierre-seguimiento': 'Cierre & Seguimiento',
      'redes-sociales': 'Redes Sociales',
      'inteligencia-artificial': 'Inteligencia Artificial',
      'liderazgo-mastermind': 'Liderazgo & Mastermind',
      'eventos-cultura': 'Eventos & Cultura',
      'construccion-residual': 'Construcción de Residual',
      'otro': 'General',
    }

    function openModal(card) {
      const id = card.dataset.id
      const title = card.dataset.title.split('|')[0].trim()
      const instructor = card.dataset.instructor
      const area = card.dataset.area
      iframe.src = `https://www.youtube.com/embed/${id}?autoplay=1&rel=0`
      modalTitle.textContent = title
      modalInstructor.textContent = instructor ? `Con ${instructor}` : 'Sesión grupal · Comunidad PECC'
      modalArea.textContent = areaLabels[area] || area
      modalYtLink.href = `https://www.youtube.com/watch?v=${id}`
      modal.classList.remove('hidden')
      modal.classList.add('flex')
      document.body.style.overflow = 'hidden'
    }
    function closeModal() {
      modal.classList.add('hidden')
      modal.classList.remove('flex')
      iframe.src = ''
      document.body.style.overflow = ''
    }

    cards.forEach((c) => c.addEventListener('click', () => openModal(c)))
    closeBtn.addEventListener('click', closeModal)
    modal.addEventListener('click', (e) => { if (e.target === modal) closeModal() })
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal()
    })
  </script>

  <style>
    .stream-card:hover {
      transform: translateY(-4px);
      border-color: rgba(167, 230, 127, 0.3) !important;
      box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4);
    }
    .line-clamp-2 {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  </style>
</Layout>
