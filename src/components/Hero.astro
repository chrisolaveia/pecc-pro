---
---

<section
  id="hero"
  aria-labelledby="hero-heading"
  class="relative min-h-screen flex items-center overflow-hidden dot-bg"
  style="padding-top: 6rem;"
>
  <!-- Glow orbs -->
  <div
    class="absolute top-[-200px] right-[-150px] w-[650px] h-[650px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(74,144,217,0.3) 0%, transparent 65%);"
  ></div>
  <div
    class="absolute bottom-[-150px] left-[-150px] w-[550px] h-[550px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(167,230,127,0.18) 0%, transparent 65%);"
  ></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 py-20 grid md:grid-cols-2 gap-12 items-center w-full">

    <!-- Copy -->
    <div class="animate-fade-up">
      <div class="section-eyebrow mb-6">Network Marketing · Educación · Liderazgo</div>

      <h1 id="hero-heading" class="text-5xl md:text-6xl leading-[1.05] mb-6">
        Impulsa tu<br />
        <span class="hero-gradient-text">negocio y liderazgo</span><br />
        en Network Marketing
      </h1>

      <p class="font-sans text-base text-[var(--color-muted)] leading-relaxed max-w-[480px] mb-8">
        PECC es el sistema educativo que sostiene nuestra red de network marketing.
        Libros, capacitaciones en vivo, eventos y herramientas construidas por
        la comunidad, para la comunidad.
      </p>

      <div class="flex flex-wrap gap-3">
        <a
          href="#ecosistema"
          class="font-sans text-sm font-bold tracking-wide px-6 py-3 rounded-lg transition-all duration-200 btn-primary no-underline"
        >
          Explorar el ecosistema
        </a>
        <a
          href="https://www.youtube.com/@peccpro"
          target="_blank"
          rel="noopener"
          class="font-sans text-sm font-bold tracking-wide px-6 py-3 rounded-lg transition-all duration-200 btn-secondary no-underline"
        >
          Ver capacitaciones
        </a>
      </div>

      <!-- Trust indicators -->
      <div class="flex items-center gap-6 mt-10 pt-8" style="border-top: 1px solid rgba(255,255,255,0.08);">
        <div>
          <div class="text-2xl font-black text-white" style="font-family: var(--font-display);">192+</div>
          <div class="font-sans text-xs text-[var(--color-muted)] mt-0.5">Capacitaciones · 6 meses</div>
        </div>
        <div style="width:1px; height:32px; background:rgba(255,255,255,0.1);"></div>
        <div>
          <div class="text-2xl font-black text-white" style="font-family: var(--font-display);">18+</div>
          <div class="font-sans text-xs text-[var(--color-muted)] mt-0.5">Líderes que enseñan</div>
        </div>
        <div style="width:1px; height:32px; background:rgba(255,255,255,0.1);"></div>
        <div>
          <div class="text-2xl font-black text-white" style="font-family: var(--font-display);">8</div>
          <div class="font-sans text-xs text-[var(--color-muted)] mt-0.5">Áreas de formación</div>
        </div>
      </div>
    </div>

    <!-- Visual: floating cards mosaic -->
    <div class="hidden md:flex justify-center items-center">
      <div class="relative animate-float">
        <!-- Central shield -->
        <div
          class="w-[360px] h-[440px] rounded-3xl relative overflow-hidden flex flex-col items-center justify-center p-8"
          style="background: linear-gradient(145deg, rgba(0,80,142,0.35), rgba(15,31,56,0.9)); border: 1px solid rgba(74,144,217,0.35); box-shadow: 0 30px 80px rgba(0,80,142,0.4);"
        >
          <!-- Decorative dots -->
          <div class="absolute inset-0 dot-bg opacity-40"></div>

          <!-- Logo glyph -->
          <div
            class="w-24 h-24 rounded-2xl flex items-center justify-center text-5xl font-black mb-6 relative"
            style="background: linear-gradient(135deg, var(--color-blue), var(--color-blue-light)); color: white; font-family: var(--font-display); box-shadow: 0 10px 40px rgba(0,80,142,0.5);"
          >P</div>

          <div class="text-center relative">
            <div class="font-sans text-[10px] tracking-[0.3em] uppercase text-[var(--color-green)] font-semibold mb-2">
              Plataforma
            </div>
            <h2 class="text-3xl font-black text-white mb-3" style="font-family: var(--font-display);">
              PECC.PRO
            </h2>
            <p class="font-sans text-sm text-[var(--color-muted)] leading-relaxed max-w-[240px] mx-auto">
              Tu sistema integral de crecimiento
            </p>
          </div>
        </div>

        <!-- Floating badge: Biblioteca -->
        <div
          class="absolute -top-5 -left-6 glass rounded-xl px-4 py-3 flex items-center gap-3"
          style="border: 1px solid rgba(167,230,127,0.3);"
        >
          <div class="w-8 h-8 rounded-lg flex items-center justify-center text-sm" style="background: rgba(167,230,127,0.15);">📚</div>
          <div>
            <div class="font-sans text-xs font-semibold text-white">Biblioteca del Éxito</div>
            <div class="font-sans text-[10px] text-[var(--color-muted)]">24 libros en vivo</div>
          </div>
        </div>

        <!-- Floating badge: Eventos -->
        <div
          class="absolute -bottom-4 -right-6 glass rounded-xl px-4 py-3 flex items-center gap-3"
          style="border: 1px solid rgba(74,144,217,0.3);"
        >
          <div class="w-8 h-8 rounded-lg flex items-center justify-center text-sm" style="background: rgba(74,144,217,0.2);">🎪</div>
          <div>
            <div class="font-sans text-xs font-semibold text-white">Eventos LIVE</div>
            <div class="font-sans text-[10px] text-[var(--color-muted)]">Online + presencial</div>
          </div>
        </div>

        <!-- Floating badge: Tienda -->
        <div
          class="absolute top-1/2 -right-8 -translate-y-1/2 glass rounded-xl px-3 py-2.5 flex items-center gap-2"
          style="border: 1px solid rgba(232,184,74,0.35);"
        >
          <span class="text-base">🛒</span>
          <div class="font-sans text-[11px] font-semibold text-white">Tienda</div>
        </div>
      </div>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40">
    <span class="font-sans text-[10px] tracking-widest uppercase text-[var(--color-muted)]">Scroll</span>
    <div class="w-px h-8" style="background: linear-gradient(to bottom, var(--color-green), transparent);"></div>
  </div>
</section>
