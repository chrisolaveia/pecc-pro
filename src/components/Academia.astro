---
import { areas, academyStats } from '../data/peccpro-areas'

const accentMap = {
  green: 'var(--color-green)',
  blue: 'var(--color-blue-light)',
  sky: 'var(--color-sky)',
  gold: 'var(--color-gold)',
}
---

<section id="academia" class="py-24 px-6 relative overflow-hidden" style="background: var(--color-navy);">
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1000px] h-[1000px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(167,230,127,0.06) 0%, transparent 60%);"
  ></div>

  <div class="relative max-w-6xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-10">
      <div class="section-eyebrow justify-center mb-4">Academia PECC</div>
      <h2 class="text-4xl md:text-5xl leading-tight mb-4">
        Las 8 áreas de <span class="green-gradient">formación</span>
      </h2>
      <p class="font-sans text-base text-[var(--color-muted)] mt-5 max-w-2xl mx-auto leading-relaxed">
        Cada semana, líderes activos de la comunidad transmiten en vivo sobre los
        ejes reales del negocio. Sin teoría prestada — sólo lo que funciona, contado
        por quien lo está aplicando.
      </p>
    </div>

    <!-- Stats strip -->
    <div class="flex flex-wrap items-center justify-center gap-6 mb-14 py-4 px-6 rounded-xl max-w-3xl mx-auto glass">
      <div class="text-center">
        <div class="text-2xl md:text-3xl font-black" style="font-family: var(--font-display); color: var(--color-green);">
          {academyStats.trainings6Months}+
        </div>
        <div class="font-sans text-[10px] tracking-widest uppercase text-[var(--color-muted)] mt-0.5">
          Capacitaciones · 6 meses
        </div>
      </div>
      <div class="h-8 w-px" style="background: rgba(255,255,255,0.1);"></div>
      <div class="text-center">
        <div class="text-2xl md:text-3xl font-black" style="font-family: var(--font-display); color: var(--color-blue-light);">
          {academyStats.instructors}+
        </div>
        <div class="font-sans text-[10px] tracking-widest uppercase text-[var(--color-muted)] mt-0.5">
          Líderes instructores
        </div>
      </div>
      <div class="h-8 w-px" style="background: rgba(255,255,255,0.1);"></div>
      <div class="text-center">
        <div class="text-2xl md:text-3xl font-black" style="font-family: var(--font-display); color: var(--color-gold);">
          {academyStats.frequencyPerWeek}/sem
        </div>
        <div class="font-sans text-[10px] tracking-widest uppercase text-[var(--color-muted)] mt-0.5">
          Streams en vivo
        </div>
      </div>
    </div>

    <!-- Areas grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-14">
      {areas.map((a) => (
        <article
          class="area-card relative rounded-2xl p-5 flex flex-col gap-3 transition-all duration-300"
          style={`background: var(--color-surface); border: 1px solid rgba(255,255,255,0.06);`}
        >
          <div
            class="absolute top-0 left-0 right-0 h-0.5 rounded-t-2xl opacity-70"
            style={`background: linear-gradient(90deg, ${accentMap[a.accent]}, transparent);`}
          ></div>

          <div class="text-3xl">{a.emoji}</div>
          <h3 class="text-base font-bold text-white leading-tight" style="font-family: var(--font-display);">
            {a.title}
          </h3>
          <p class="font-sans text-xs text-[var(--color-muted)] leading-relaxed">
            {a.description}
          </p>

          <ul class="mt-auto pt-3 space-y-1 list-none" style="border-top: 1px solid rgba(255,255,255,0.06);">
            {a.examples.map((ex) => (
              <li class="font-sans text-[11px] leading-snug flex items-start gap-1.5" style={`color: ${accentMap[a.accent]};`}>
                <span class="mt-0.5 flex-shrink-0">·</span>
                <span class="text-[var(--color-muted)]">{ex}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <!-- Community strip -->
    <div
      class="rounded-2xl p-8 md:p-10 text-center"
      style="background: linear-gradient(135deg, rgba(0,80,142,0.15), rgba(167,230,127,0.08)); border: 1px solid rgba(167,230,127,0.18);"
    >
      <div class="font-sans text-[10px] tracking-[0.3em] uppercase font-bold mb-3" style="color: var(--color-green);">
        Quienes enseñan
      </div>
      <h3 class="text-2xl md:text-3xl mb-4 text-white" style="font-family: var(--font-display);">
        Los que ya lo están logrando
      </h3>
      <p class="font-sans text-sm text-[var(--color-muted)] leading-relaxed max-w-2xl mx-auto mb-6">
        Cada capacitación la dicta un líder activo de la comunidad que aplica lo
        que enseña. No son teóricos externos — son networkers que construyeron
        y siguen construyendo mientras transmiten.
      </p>
      <a
        href="https://www.youtube.com/@peccpro/streams"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 font-sans text-sm font-bold px-6 py-3 rounded-lg transition-all btn-primary no-underline"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
        Ver capacitaciones en vivo
      </a>
    </div>

  </div>
</section>

<style>
  .area-card:hover {
    transform: translateY(-4px);
    border-color: rgba(167, 230, 127, 0.3) !important;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4);
  }
</style>
