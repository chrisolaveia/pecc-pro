---
const beneficios = [
  {
    icon: '🎓',
    title: 'Educación continua',
    desc: 'Lectura semanal en vivo, análisis de libros clásicos y modernos del network marketing.',
  },
  {
    icon: '🏆',
    title: 'Método probado',
    desc: 'Inspirado en los sistemas que construyeron las organizaciones más grandes — desde Dexter Yager hasta los actuales.',
  },
  {
    icon: '🤝',
    title: 'Comunidad activa',
    desc: 'Aprendes con pares que aplican lo mismo que tú. No eres el único en el camino.',
  },
  {
    icon: '📈',
    title: 'Aplicación práctica',
    desc: 'No es teoría. Cada aprendizaje se convierte en acción concreta para tu organización.',
  },
]
---

<section id="academia" class="py-24 px-6 relative overflow-hidden" style="background: var(--color-navy);">
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[900px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(167,230,127,0.06) 0%, transparent 60%);"
  ></div>

  <div class="relative max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center">

    <!-- Left: copy -->
    <div>
      <div class="section-eyebrow mb-5">Academia PECC</div>
      <h2 class="text-4xl md:text-5xl leading-tight mb-6">
        Leer, aplicar,<br />
        <span class="green-gradient">duplicar</span>
      </h2>

      <div class="space-y-4 mb-8">
        <p class="font-sans text-sm text-[var(--color-muted)] leading-relaxed">
          La Academia PECC es el motor educativo de la comunidad. Cada semana
          leemos en vivo un libro completo de los clásicos del network marketing,
          liderazgo y desarrollo personal.
        </p>
        <p class="font-sans text-sm text-[var(--color-muted)] leading-relaxed">
          No es un podcast. No es un resumen. Es un sistema estructurado de
          formación continua, al estilo de las grandes escuelas de MLM: leer,
          aplicar con tu equipo, y duplicar el conocimiento en la siguiente
          generación de líderes.
        </p>
      </div>

      <a
        href="https://chrisolave.me/biblioteca"
        class="inline-flex items-center gap-2 font-sans text-sm font-bold px-6 py-3 rounded-lg transition-all duration-200 btn-primary no-underline"
      >
        Ver los 24 libros
        <span>→</span>
      </a>
    </div>

    <!-- Right: benefits grid -->
    <div class="grid grid-cols-2 gap-4">
      {beneficios.map((b) => (
        <div
          class="rounded-2xl p-5"
          style="background: var(--color-surface); border: 1px solid rgba(255,255,255,0.06);"
        >
          <div class="text-3xl mb-3">{b.icon}</div>
          <h3 class="text-sm font-bold text-white mb-2" style="font-family: var(--font-display);">
            {b.title}
          </h3>
          <p class="font-sans text-xs text-[var(--color-muted)] leading-relaxed">
            {b.desc}
          </p>
        </div>
      ))}
    </div>

  </div>
</section>
