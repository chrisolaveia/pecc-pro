---
---

<section
  id="contacto"
  class="relative py-28 px-6 overflow-hidden text-center"
  style="background: var(--color-navy);"
>
  <!-- Spotlight -->
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(74,144,217,0.18) 0%, rgba(167,230,127,0.06) 40%, transparent 70%);"
  ></div>
  <div class="absolute inset-0 dot-bg opacity-40 pointer-events-none"></div>

  <div class="relative z-10 max-w-3xl mx-auto">
    <div class="section-eyebrow justify-center mb-5">¿Listo para crecer?</div>

    <h2 class="text-4xl md:text-5xl mb-6 leading-tight">
      Únete a <span class="hero-gradient-text">la comunidad</span>
    </h2>

    <p class="font-sans text-base text-[var(--color-muted)] leading-relaxed mb-10 max-w-xl mx-auto">
      Si tienes visión, disciplina y ganas de construir una economía desde
      el network marketing, este es tu lugar. Empieza con una llamada 1:1
      o explora el ecosistema por tu cuenta.
    </p>

    <div class="flex flex-wrap justify-center gap-3 mb-12">
      <a
        href="/agenda"
        class="font-sans text-sm font-bold tracking-wide px-7 py-3.5 rounded-lg transition-all duration-200 btn-primary no-underline"
      >
        Agendar llamada 1:1
      </a>
      <a
        href="https://chrisolave.me/comunidad"
        target="_blank"
        rel="noopener"
        class="font-sans text-sm font-bold tracking-wide px-7 py-3.5 rounded-lg transition-all duration-200 btn-secondary no-underline"
      >
        Conocer EquipoGen
      </a>
    </div>

    <!-- Social strip -->
    <div class="flex items-center justify-center gap-8 pt-10" style="border-top: 1px solid rgba(255,255,255,0.08);">
      <a
        href="https://www.youtube.com/@peccpro"
        target="_blank"
        rel="noopener"
        aria-label="YouTube PECC"
        class="text-[var(--color-muted)] hover:text-white transition-colors"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
      </a>
      <a
        href="https://www.youtube.com/@chrisolave"
        target="_blank"
        rel="noopener"
        class="font-sans text-xs font-semibold text-[var(--color-muted)] hover:text-white transition-colors"
      >@chrisolave</a>
      <a
        href="https://tienda.pecc.pro"
        target="_blank"
        rel="noopener"
        class="font-sans text-xs font-semibold text-[var(--color-muted)] hover:text-white transition-colors"
      >Tienda</a>
      <a
        href="https://eventos.pecc.pro"
        target="_blank"
        rel="noopener"
        class="font-sans text-xs font-semibold text-[var(--color-muted)] hover:text-white transition-colors"
      >Eventos</a>
    </div>
  </div>
</section>
