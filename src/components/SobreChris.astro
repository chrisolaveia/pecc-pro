---
---

<section class="py-24 px-6" style="background: var(--color-surface);">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-12">
      <div class="section-eyebrow justify-center mb-4">Fundador</div>
      <h2 class="text-4xl md:text-5xl">
        Detrás de PECC:<br />
        <span class="blue-gradient">Chris Olave</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-8 items-start">

      <div class="md:col-span-1">
        <div
          class="aspect-square rounded-2xl overflow-hidden relative"
          style="background: linear-gradient(145deg, rgba(0,80,142,0.2), rgba(15,31,56,0.9)); border: 1px solid rgba(74,144,217,0.3);"
        >
          <img
            src="https://chrisolave.me/chris-olave.webp"
            alt="Chris Olave, fundador de PECC y líder de EquipoGen"
            width="400"
            height="400"
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover object-top"
          />
        </div>
      </div>

      <div class="md:col-span-2 space-y-4">
        <p class="font-sans text-base text-[var(--color-muted)] leading-relaxed">
          <strong class="text-white">Chris Olave</strong> es emprendedor chileno,
          fundador de <strong class="text-white">MINED</strong> (AI Creators Academy)
          y <strong class="text-white">FWP</strong> (bienestar y salud), y líder de
          <strong class="text-white">EquipoGen</strong>, comunidad internacional de
          network marketing que trabaja a nivel nacional e internacional junto a
          su patrocinador.
        </p>

        <p class="font-sans text-sm text-[var(--color-muted)] leading-relaxed">
          PECC es la infraestructura que sostiene la comunidad: educación continua,
          eventos, herramientas y una visión clara — construir una economía basada
          en relaciones, conocimiento y acción.
        </p>

        <div class="flex flex-wrap gap-3 pt-4">
          <a
            href="https://chrisolave.me"
            target="_blank"
            rel="noopener"
            class="font-sans text-xs font-bold tracking-wide px-5 py-2.5 rounded-lg transition-all duration-200 btn-secondary no-underline"
          >
            chrisolave.me
          </a>
          <a
            href="https://www.youtube.com/@chrisolave"
            target="_blank"
            rel="noopener"
            class="font-sans text-xs font-bold tracking-wide px-5 py-2.5 rounded-lg transition-all duration-200 no-underline flex items-center gap-2"
            style="background: rgba(255,255,255,0.04); color: white; border: 1px solid rgba(255,255,255,0.1);"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
            YouTube
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
